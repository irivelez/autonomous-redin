# AppSheet (Redin's "Active" app)
APPSHEET_APP_ID=
APPSHEET_ACCESS_KEY=

# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=

# Manager identity
# MANAGER_PHONE = E.164 phone (any format, we normalize) — when this person
# shares their contact on /start they are enrolled as "manager".
MANAGER_PHONE=+573166222563

# MANAGER_TELEGRAM_CHAT_ID (optional override). If set, alerts and approval
# requests are routed here even before the manager enrolls. Otherwise the
# first user enrolled as manager becomes the alert recipient automatically.
# MANAGER_TELEGRAM_CHAT_ID=

# Google AI Studio — Gemini API key for LLM interpretation
GEMINI_API_KEY=

# Where to persist the Telegram user registry (JSON file).
# On Railway, mount a volume here so enrollments survive redeploys.
TELEGRAM_DATA_DIR=/data/telegram

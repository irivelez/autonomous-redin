# AppSheet (Redin's "Active" app)
APPSHEET_APP_ID=
APPSHEET_ACCESS_KEY=

# WhatsApp (Baileys — no credentials needed, QR scan via /pair on first run)
# Auth state persists in WA_AUTH_DIR. For Railway, mount a volume here.
WA_AUTH_DIR=/data/whatsapp-auth

# Manager's WhatsApp for critical alerts (E.164 format, no +, no spaces)
MANAGER_WHATSAPP=573166222563

# HTTP pair server — Railway injects PORT automatically; set 3000 locally.
PORT=3000

# Token that protects the /pair URL. Use a random 24+ char string.
# Without this, anyone who finds the Railway URL could see the QR.
PAIR_TOKEN=

# Optional: pair via 8-digit code instead of QR (E.164 digits, no +).
# Used by `npm run pair` only. Not needed for the HTTP flow.
# PAIRING_PHONE=573166222563
